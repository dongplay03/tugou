# TuGou Catcher environment example

# Backend HTTP/WebSocket port
PORT=3001

# Recommended: set a non-empty API key before exposing beyond localhost.
# When API_KEY is empty, the backend currently permits unauthenticated API access.
API_KEY=change-me
# Backward-compatible legacy name also supported by backend/src/server.ts
TUGOU_API_KEY=change-me

# Restrict CORS origins with comma-separated values.
# Example: http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Explicitly enable raw database workbench APIs.
# Keep false unless you are doing local maintenance.
ENABLE_DB_WORKBENCH=false

# Optional custom database path. Defaults to backend/data/tugoucatcher.db
# DB_PATH=/Users/limindong/data/tugoucatcher/tugoucatcher.db

# External providers
DEXSCREENER_API_BASE=https://api.dexscreener.com
RUGCHECK_API_BASE=https://api.rugcheck.xyz
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional enrichment providers. Never commit real keys.
AVE_API_KEY=change-me
AVEAI_API_KEY=change-me
AVEAI_API_BASE=https://prod.ave-api.com
BIRDEYE_API_KEY=change-me
X_BEARER_TOKEN=change-me

# AI Analyzer (Strategy 17) — uses Nous Portal (free) by default
# Falls back to OpenRouter if Nous token unavailable
# NOUS_AUTH_FILE=/Users/limindong/.hermes/shared/nous_auth.json
# OPENROUTER_API_KEY=change-me  # fallback only
# AI_ANALYZER_MODEL=arcee-ai/trinity-large-thinking
# AI_ANALYZER_BASE_URL=https://inference-api.nousresearch.com/v1
# AI_ANALYZER_DISABLED=false
